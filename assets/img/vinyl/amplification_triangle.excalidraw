      "boundElements": null,
      "link": null,
      "locked": false,
      "roundness": null,
      "text": "\u2190 \u0431\u043e\u043b\u044c\u0448\u0435 \u0441\u043b\u0438\u044f\u043d\u0438\u0439\n\u0434\u0435\u0448\u0435\u0432\u043b\u0435 \u0447\u0442\u0435\u043d\u0438\u0435,\n\u0431\u043e\u043b\u044c\u0448\u0435 \u043c\u0443\u0441\u043e\u0440\u0430",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "right",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\u2190 \u0431\u043e\u043b\u044c\u0448\u0435 \u0441\u043b\u0438\u044f\u043d\u0438\u0439\n\u0434\u0435\u0448\u0435\u0432\u043b\u0435 \u0447\u0442\u0435\u043d\u0438\u0435,\n\u0431\u043e\u043b\u044c\u0448\u0435 \u043c\u0443\u0441\u043e\u0440\u0430",
      "autoResize": true,
      "lineHeight": 1.25
    },
