      "link": null,
      "locked": false,
      "roundness": null,
      "text": "\u043c\u0435\u043d\u044c\u0448\u0435 \u0441\u043b\u0438\u044f\u043d\u0438\u0439 \u2192\n\u0434\u0435\u0448\u0435\u0432\u043b\u0435 \u0437\u0430\u043f\u0438\u0441\u044c,\n\u0434\u043e\u0440\u043e\u0436\u0435 \u0447\u0442\u0435\u043d\u0438\u0435",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\u043c\u0435\u043d\u044c\u0448\u0435 \u0441\u043b\u0438\u044f\u043d\u0438\u0439 \u2192\n\u0434\u0435\u0448\u0435\u0432\u043b\u0435 \u0437\u0430\u043f\u0438\u0441\u044c,\n\u0434\u043e\u0440\u043e\u0436\u0435 \u0447\u0442\u0435\u043d\u0438\u0435",
      "autoResize": true,
      "lineHeight": 1.25
    },
